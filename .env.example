# AXON — Environment Variables Template
# Copy to .env and fill in real values. Never commit .env.

# ========== Core ==========
NODE_ENV=development
APP_ENV=local

# ========== Database (local dev via docker-compose) ==========
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=axon
POSTGRES_USER=axon
POSTGRES_PASSWORD=axon_dev_password
DATABASE_URL=postgresql://axon:axon_dev_password@localhost:5432/axon

# ========== Backend (NestJS) ==========
BACKEND_PORT=4000
# v1 has no login — JWT secret is still required for future and for internal service auth
JWT_SECRET=replace-me-with-openssl-rand-hex-32
JWT_EXPIRES_IN=24h

# ========== Frontend (React + Vite) ==========
VITE_API_BASE_URL=http://localhost:4000
VITE_SSE_ENABLED=true

# ========== AI Proxy (FastAPI) ==========
AI_PROXY_PORT=8080
AI_PROXY_URL=http://localhost:8080
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
AI_PROXY_PER_AUDIT_COST_CAP_USD=0.50

# ========== Worker ==========
WORKER_PORT=9090
WORKER_URL=http://localhost:9090
# Playwright settings
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=30000

# Residential proxy provider (fill in when you have an account)
PROXY_PROVIDER=oxylabs
PROXY_ENDPOINT=pr.oxylabs.io:7777
PROXY_USERNAME=
PROXY_PASSWORD=

# Scrape throttling
SCRAPE_MIN_DELAY_MS=3000
SCRAPE_MAX_DELAY_MS=8000
SCRAPE_MAX_CONCURRENCY_PER_AUDIT=4

# Safety caps (per plan)
AUDIT_SOFT_ASIN_WARNING=500
AUDIT_HARD_ASIN_CEILING=2000
AUDIT_SOFT_REVIEW_WARNING=20000
AUDIT_HARD_REVIEW_CEILING=50000

# ========== GCP ==========
GCP_PROJECT_ID=axon-494010
GCP_REGION=us-central1
GCS_REPORTS_BUCKET=axon-reports
CLOUD_TASKS_QUEUE=axon-audit-queue
# Use local filesystem in dev when blank
GOOGLE_APPLICATION_CREDENTIALS=

# ========== Queue (local: in-process; prod: Cloud Tasks) ==========
QUEUE_BACKEND=in-process
# set to "cloud-tasks" in prod

# ========== Default tenant (v1 pre-auth) ==========
DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001
DEFAULT_ORG_NAME=AXON Internal
